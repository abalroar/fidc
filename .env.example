# Credenciais do ANBIMA Feed (developers.anbima.com.br) — NUNCA commitar o .env real.
ANBIMA_CLIENT_ID=
ANBIMA_CLIENT_SECRET=

# production | sandbox
ANBIMA_ENV=production

# URL do endpoint de token OAuth2 (default confirmado; atende produção e sandbox).
# ANBIMA_TOKEN_URL=https://api.anbima.com.br/oauth/access-token

# Intervalo mínimo entre chamadas, em segundos (rate limit de produção ~15 req/s).
ANBIMA_SLEEP_SECONDS=0.1
